generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id                        String                     @id @default(cuid())
  email                     String                     @unique
  name                      String
  role                      String
  status                    String                     @default("ACTIVE")
  passwordHash              String?
  lastLoginAt               DateTime?
  companyId                 String?
  company                   Company?                   @relation(fields: [companyId], references: [id])
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
  createdOrders             Order[]                    @relation("OrderCreatedBy")
  approvedOrders            Order[]                    @relation("OrderApprovedBy")
  pageRevisions             PageRevision[]
  sessions                  AuthSession[]
  auditLogs                 AuditLog[]
  activationTokens          UserActivationToken[]
  passwordResetTokens       UserPasswordResetToken[]
  quoteRequests             QuoteRequest[]             @relation("QuoteRequester")
  quoteCarts                QuoteCart[]
  orderCarts                OrderCart[]
  orderStatusChanges        OrderStatusHistory[]       @relation("OrderStatusChangedBy")
  orderTransitionCommands   OrderTransitionCommand[]   @relation("OrderTransitionCommandCreatedBy")
  quoteStatusChanges        QuoteStatusHistory[]       @relation("QuoteStatusChangedBy")
  quoteOperationCommands    QuoteOperationCommand[]    @relation("QuoteOperationCommandCreatedBy")
  quoteOfferRevisions       QuoteOfferRevision[]       @relation("QuoteOfferRevisionCreatedBy")
  integrationReplayCommands IntegrationReplayCommand[]

  @@index([companyId, role, status])
}

model UserActivationToken {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId, consumedAt, revokedAt])
  @@index([expiresAt])
}

model UserPasswordResetToken {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId, consumedAt, revokedAt])
  @@index([expiresAt])
}

model AuthSession {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Company {
  id                  String              @id @default(cuid())
  legalName           String
  displayName         String
  taxOffice           String?
  taxNumber           String?
  email               String
  phone               String
  city                String
  country             String              @default("TR")
  status              String              @default("PENDING")
  paymentTerms        String?
  creditLimit         Decimal?
  customerGroupId     String?
  customerGroup       CustomerGroup?      @relation(fields: [customerGroupId], references: [id])
  assignedSalesUserId String?
  internalNotes       String?
  users               User[]
  addresses           Address[]
  dealerApplications  DealerApplication[]
  quoteRequests       QuoteRequest[]
  quoteCarts          QuoteCart[]
  orderCarts          OrderCart[]
  orders              Order[]
  priceLists          PriceList[]
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
}

model CustomerGroup {
  id          String      @id @default(cuid())
  code        String      @unique
  name        String
  description String?
  companies   Company[]
  priceLists  PriceList[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model DealerApplication {
  id            String    @id @default(cuid())
  companyName   String
  contactName   String
  email         String
  phone         String
  city          String
  taxNumber     String?
  customerType  String
  message       String?
  status        String    @default("NEW")
  companyId     String?
  company       Company?  @relation(fields: [companyId], references: [id])
  reviewedById  String?
  reviewedAt    DateTime?
  internalNotes String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status, createdAt])
  @@index([companyId])
}

model Address {
  id         String   @id @default(cuid())
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  label      String
  line1      String
  line2      String?
  district   String?
  city       String
  country    String   @default("TR")
  postalCode String?
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  orders     Order[]

  @@index([companyId, isDefault])
}

model ProductCategory {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  description String?
  sortOrder   Int       @default(0)
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id                 String                 @id @default(cuid())
  code               String                 @unique
  name               String
  categoryId         String
  category           ProductCategory        @relation(fields: [categoryId], references: [id])
  vehicleBrand       String?
  vehicleModel       String?
  yearStart          Int?
  yearEnd            Int?
  glassPosition      String?
  glassType          String
  dimensions         String?
  thicknessMm        Decimal?
  tint               String?
  isTempered         Boolean                @default(false)
  isLaminated        Boolean                @default(false)
  processingNotes    String?
  compatibilityNotes String?
  isCustomAvailable  Boolean                @default(false)
  orderMode          String                 @default("ORDER_ONLY")
  status             String                 @default("ACTIVE")
  stockItems         StockItem[]
  prices             ProductPrice[]
  compatibilities    ProductCompatibility[]
  quoteItems         QuoteRequestItem[]
  quoteCartItems     QuoteCartItem[]
  orderCartItems     OrderCartItem[]
  orderItems         OrderItem[]
  mediaAssets        MediaAsset[]
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  @@index([code])
  @@index([vehicleBrand, vehicleModel])
  @@index([glassType])
}

model ProductCompatibility {
  id           String   @id @default(cuid())
  productId    String
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  vehicleBrand String
  vehicleModel String
  yearStart    Int?
  yearEnd      Int?
  oemReference String?
  notes        String?
  createdAt    DateTime @default(now())
}

model PriceList {
  id              String         @id @default(cuid())
  name            String
  currency        String         @default("TRY")
  customerGroupId String?
  customerGroup   CustomerGroup? @relation(fields: [customerGroupId], references: [id])
  companyId       String?
  company         Company?       @relation(fields: [companyId], references: [id])
  startsAt        DateTime       @default(now())
  endsAt          DateTime?
  isActive        Boolean        @default(true)
  priority        Int            @default(0)
  prices          ProductPrice[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model ProductPrice {
  id          String    @id @default(cuid())
  productId   String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  priceListId String
  priceList   PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  amount      Decimal
  minQuantity Int       @default(1)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([productId, priceListId, minQuantity])
}

model StockItem {
  id               String             @id @default(cuid())
  productId        String
  product          Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouseCode    String
  quantity         Int                @default(0)
  reservedQuantity Int                @default(0)
  visibility       String             @default("SIMPLIFIED")
  status           String             @default("ASK_FOR_AVAILABILITY")
  reservations     StockReservation[]
  updatedAt        DateTime           @updatedAt

  @@unique([productId, warehouseCode])
}

model QuoteRequest {
  id                    String                  @id @default(cuid())
  quoteNumber           String                  @unique
  companyId             String?
  company               Company?                @relation(fields: [companyId], references: [id])
  requesterUserId       String?
  requester             User?                   @relation("QuoteRequester", fields: [requesterUserId], references: [id])
  requesterName         String
  requesterEmail        String
  requesterPhone        String?
  customerType          String?
  desiredDeliveryDate   DateTime?
  status                String                  @default("NEW")
  notes                 String?
  internalNotes         String?
  currency              String                  @default("TRY")
  estimatedSubtotal     Decimal?
  hasUnpricedItems      Boolean                 @default(false)
  submittedAt           DateTime?
  pricedAt              DateTime?
  idempotencyKey        String?
  requestHash           String?
  sourceCartId          String?
  sourceCartVersion     Int?
  items                 QuoteRequestItem[]
  version               Int                     @default(1)
  statusHistory         QuoteStatusHistory[]
  operationCommands     QuoteOperationCommand[]
  offerRevisions        QuoteOfferRevision[]    @relation("QuoteOfferRevisions")
  convertedOrder        Order?                  @relation("QuoteConvertedOrder")
  activeOfferRevisionId String?                 @unique
  activeOfferRevision   QuoteOfferRevision?     @relation("ActiveQuoteOfferRevision", fields: [activeOfferRevisionId], references: [id], onDelete: SetNull)
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt

  @@unique([companyId, idempotencyKey])
  @@index([companyId, status, createdAt])
  @@index([companyId, createdAt])
  @@index([requesterUserId, status, createdAt])
}

model QuoteOfferRevision {
  id             String                   @id @default(cuid())
  quoteId        String
  quote          QuoteRequest             @relation("QuoteOfferRevisions", fields: [quoteId], references: [id], onDelete: Restrict)
  revisionNumber Int
  currency       String
  subtotal       Decimal
  validUntil     DateTime?
  internalNotes  String?
  createdById    String?
  createdBy      User?                    @relation("QuoteOfferRevisionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  items          QuoteOfferRevisionItem[]
  activeForQuote QuoteRequest?            @relation("ActiveQuoteOfferRevision")
  convertedOrder Order?                   @relation("QuoteConvertedOfferRevision")
  createdAt      DateTime                 @default(now())

  @@unique([quoteId, revisionNumber])
  @@index([quoteId, createdAt])
}

model QuoteOfferRevisionItem {
  id                  String             @id @default(cuid())
  revisionId          String
  revision            QuoteOfferRevision @relation(fields: [revisionId], references: [id], onDelete: Restrict)
  quoteRequestItemId  String
  quoteRequestItem    QuoteRequestItem   @relation(fields: [quoteRequestItemId], references: [id], onDelete: Restrict)
  quantitySnapshot    Int
  unitPrice           Decimal
  lineTotal           Decimal
  productCodeSnapshot String?
  productNameSnapshot String?
  dimensionsSnapshot  String?
  glassTypeSnapshot   String?
  convertedOrderItem  OrderItem?         @relation("QuoteRevisionOrderItem")

  @@unique([revisionId, quoteRequestItemId])
  @@index([quoteRequestItemId])
}

model QuoteStatusHistory {
  id          String       @id @default(cuid())
  quoteId     String
  quote       QuoteRequest @relation(fields: [quoteId], references: [id], onDelete: Restrict)
  fromStatus  String?
  toStatus    String
  changedById String?
  changedBy   User?        @relation("QuoteStatusChangedBy", fields: [changedById], references: [id], onDelete: SetNull)
  note        String?
  createdAt   DateTime     @default(now())

  @@index([quoteId, createdAt])
}

model QuoteOperationCommand {
  id             String       @id @default(cuid())
  quoteId        String
  quote          QuoteRequest @relation(fields: [quoteId], references: [id], onDelete: Restrict)
  idempotencyKey String
  operation      String
  requestHash    String
  fromStatus     String
  toStatus       String
  resultVersion  Int
  resultOrderId  String?      @unique
  resultOrder    Order?       @relation("QuoteConversionCommand", fields: [resultOrderId], references: [id], onDelete: Restrict)
  createdById    String?
  createdBy      User?        @relation("QuoteOperationCommandCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt      DateTime     @default(now())

  @@unique([quoteId, idempotencyKey])
  @@index([quoteId, createdAt])
}

model QuoteRequestItem {
  id                 String                   @id @default(cuid())
  quoteRequestId     String
  quoteRequest       QuoteRequest             @relation(fields: [quoteRequestId], references: [id], onDelete: Cascade)
  productId          String?
  product            Product?                 @relation(fields: [productId], references: [id])
  customTitle        String?
  quantity           Int                      @default(1)
  unitPrice          Decimal?
  lineTotal          Decimal?
  priceListId        String?
  priceMinQuantity   Int?
  priceScope         String?
  dimensions         String?
  glassType          String?
  notes              String?
  offerRevisionItems QuoteOfferRevisionItem[]

  @@unique([quoteRequestId, productId])
  @@index([quoteRequestId])
}

model QuoteCart {
  id          String          @id @default(cuid())
  companyId   String
  company     Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  ownerUserId String
  ownerUser   User            @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  items       QuoteCartItem[]
  version     Int             @default(1)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@unique([companyId, ownerUserId])
  @@index([ownerUserId])
}

model QuoteCartItem {
  id        String    @id @default(cuid())
  cartId    String
  cart      QuoteCart @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   Product   @relation(fields: [productId], references: [id])
  quantity  Int       @default(1)
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([cartId, productId])
  @@index([cartId])
}

model OrderCart {
  id          String          @id @default(cuid())
  companyId   String
  company     Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  ownerUserId String
  ownerUser   User            @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  items       OrderCartItem[]
  version     Int             @default(1)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@unique([companyId, ownerUserId])
  @@index([ownerUserId])
}

model OrderCartItem {
  id        String    @id @default(cuid())
  cartId    String
  cart      OrderCart @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   Product   @relation(fields: [productId], references: [id])
  quantity  Int       @default(1)
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([cartId, productId])
  @@index([cartId])
}

model Order {
  id                     String                   @id @default(cuid())
  orderNumber            String                   @unique
  companyId              String
  company                Company                  @relation(fields: [companyId], references: [id])
  status                 String                   @default("DRAFT")
  currency               String                   @default("TRY")
  subtotal               Decimal                  @default(0)
  deliveryAddressId      String?
  deliveryAddress        Address?                 @relation(fields: [deliveryAddressId], references: [id], onDelete: SetNull)
  deliveryLabel          String?
  deliveryLine1          String?
  deliveryLine2          String?
  deliveryDistrict       String?
  deliveryCity           String?
  deliveryCountry        String?
  deliveryPostalCode     String?
  requestedDeliveryDate  DateTime?
  shipmentMethod         String?
  notes                  String?
  internalNotes          String?
  createdById            String?
  createdBy              User?                    @relation("OrderCreatedBy", fields: [createdById], references: [id])
  approvedById           String?
  approvedBy             User?                    @relation("OrderApprovedBy", fields: [approvedById], references: [id])
  items                  OrderItem[]
  statusHistory          OrderStatusHistory[]
  shipment               Shipment?
  submittedAt            DateTime?
  pricedAt               DateTime?
  idempotencyKey         String?
  requestHash            String?
  sourceCartId           String?
  sourceCartVersion      Int?
  sourceQuoteId          String?                  @unique
  sourceQuote            QuoteRequest?            @relation("QuoteConvertedOrder", fields: [sourceQuoteId], references: [id], onDelete: Restrict)
  sourceQuoteVersion     Int?
  sourceOfferRevisionId  String?                  @unique
  sourceOfferRevision    QuoteOfferRevision?      @relation("QuoteConvertedOfferRevision", fields: [sourceOfferRevisionId], references: [id], onDelete: Restrict)
  quoteConversionCommand QuoteOperationCommand?   @relation("QuoteConversionCommand")
  version                Int                      @default(1)
  heldFromStatus         String?
  transitionCommands     OrderTransitionCommand[]
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt

  @@unique([companyId, idempotencyKey])
  @@index([companyId, status, createdAt])
  @@index([companyId, createdAt])
}

model OrderItem {
  id                        String                  @id @default(cuid())
  orderId                   String
  order                     Order                   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId                 String
  product                   Product                 @relation(fields: [productId], references: [id])
  quantity                  Int
  unitPrice                 Decimal?
  lineTotal                 Decimal?
  productCodeSnapshot       String                  @default("")
  productNameSnapshot       String                  @default("")
  dimensionsSnapshot        String?
  glassTypeSnapshot         String                  @default("")
  sourceProductPriceId      String?
  priceListId               String?
  priceMinQuantity          Int?
  priceScope                String?
  notes                     String?
  sourceOfferRevisionItemId String?                 @unique
  sourceOfferRevisionItem   QuoteOfferRevisionItem? @relation("QuoteRevisionOrderItem", fields: [sourceOfferRevisionItemId], references: [id], onDelete: Restrict)
  reservations              StockReservation[]

  @@unique([orderId, productId])
  @@index([orderId])
}

model StockReservation {
  id            String    @id @default(cuid())
  orderItemId   String
  orderItem     OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Restrict)
  stockItemId   String
  stockItem     StockItem @relation(fields: [stockItemId], references: [id], onDelete: Restrict)
  quantity      Int
  status        String    @default("ACTIVE")
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())
  releasedAt    DateTime?
  consumedAt    DateTime?
  releaseReason String?
  updatedAt     DateTime  @updatedAt

  @@unique([orderItemId, stockItemId])
  @@index([stockItemId, status])
  @@index([status, expiresAt])
}

model CheckoutLock {
  id        String   @id
  version   Int      @default(0)
  updatedAt DateTime @updatedAt
}

model OrderStatusHistory {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fromStatus  String?
  toStatus    String
  changedById String?
  changedBy   User?    @relation("OrderStatusChangedBy", fields: [changedById], references: [id], onDelete: SetNull)
  note        String?
  createdAt   DateTime @default(now())
}

model OrderTransitionCommand {
  id             String   @id @default(cuid())
  orderId        String
  order          Order    @relation(fields: [orderId], references: [id], onDelete: Restrict)
  idempotencyKey String
  requestHash    String
  fromStatus     String
  toStatus       String
  resultVersion  Int
  createdById    String?
  createdBy      User?    @relation("OrderTransitionCommandCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt      DateTime @default(now())

  @@unique([orderId, idempotencyKey])
  @@index([orderId, createdAt])
}

model Shipment {
  id                 String            @id @default(cuid())
  orderId            String            @unique
  order              Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  providerId         String?
  provider           ShippingProvider? @relation(fields: [providerId], references: [id])
  carrier            String?
  trackingNumber     String?
  externalShipmentId String?
  trackingUrl        String?
  labelUrl           String?
  rawStatus          String?
  status             String            @default("PENDING")
  shippedAt          DateTime?
  deliveredAt        DateTime?
  events             ShipmentEvent[]
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@index([status, updatedAt])
}

model ShipmentEvent {
  id          String   @id @default(cuid())
  shipmentId  String
  shipment    Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  eventCode   String
  title       String
  description String?
  occurredAt  DateTime
  location    String?
  rawPayload  String?
  createdAt   DateTime @default(now())

  @@index([shipmentId, occurredAt])
}

model ShippingProvider {
  id              String           @id @default(cuid())
  code            String           @unique
  name            String
  providerType    String
  baseUrl         String?
  accountNumber   String?
  credentialsKey  String?
  isActive        Boolean          @default(false)
  supportsLabels  Boolean          @default(false)
  supportsWebhook Boolean          @default(false)
  notes           String?
  shipments       Shipment[]
  logs            IntegrationLog[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model MediaAsset {
  id               String      @id @default(cuid())
  key              String      @unique
  title            String
  url              String
  altText          String
  usage            String
  productId        String?
  product          Product?    @relation(fields: [productId], references: [id])
  pageBlocks       PageBlock[]
  isActive         Boolean     @default(true)
  objectKey        String?     @unique
  mimeType         String?
  byteSize         Int?
  checksum         String?
  storageProvider  String?
  uploadedByUserId String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}

model SiteSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  label       String
  value       String
  valueType   String   @default("TEXT")
  group       String
  description String?
  isEditable  Boolean  @default(true)
  updatedAt   DateTime @updatedAt
}

model Page {
  id             String         @id @default(cuid())
  slug           String         @unique
  title          String
  status         String         @default("DRAFT")
  locale         String         @default("tr")
  seoTitle       String?
  seoDescription String?
  publishedAt    DateTime?
  blocks         PageBlock[]
  revisions      PageRevision[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model PageBlock {
  id           String      @id @default(cuid())
  pageId       String
  page         Page        @relation(fields: [pageId], references: [id], onDelete: Cascade)
  type         String
  sortOrder    Int         @default(0)
  title        String?
  eyebrow      String?
  body         String?
  ctaLabel     String?
  ctaHref      String?
  mediaAssetId String?
  mediaAsset   MediaAsset? @relation(fields: [mediaAssetId], references: [id])
  settingsJson String?
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([pageId, sortOrder])
}

model PageRevision {
  id           String   @id @default(cuid())
  pageId       String
  page         Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  version      Int
  snapshotJson String
  createdById  String?
  createdBy    User?    @relation(fields: [createdById], references: [id])
  createdAt    DateTime @default(now())

  @@unique([pageId, version])
}

model DashboardWidget {
  id          String   @id @default(cuid())
  key         String   @unique
  title       String
  description String?
  role        String
  metricKey   String
  icon        String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  actor       User?    @relation(fields: [actorUserId], references: [id])
  action      String
  entityType  String
  entityId    String?
  metadata    String?
  createdAt   DateTime @default(now())

  @@index([entityType, entityId, createdAt])
}

model IntegrationLog {
  id              String                  @id @default(cuid())
  providerId      String?
  provider        ShippingProvider?       @relation(fields: [providerId], references: [id])
  direction       String
  operation       String
  status          String
  entityType      String?
  entityId        String?
  requestSummary  String?
  responseSummary String?
  errorMessage    String?
  retryCount      Int                     @default(0)
  outboxEventId   String?
  outboxEvent     IntegrationOutboxEvent? @relation(fields: [outboxEventId], references: [id], onDelete: SetNull)
  createdAt       DateTime                @default(now())

  @@index([providerId, createdAt])
  @@index([entityType, entityId])
  @@index([outboxEventId, createdAt])
}

model IntegrationOutboxEvent {
  id             String                     @id @default(cuid())
  topic          String
  eventType      String
  aggregateType  String
  aggregateId    String
  providerCode   String?
  payload        String
  idempotencyKey String                     @unique
  status         String                     @default("PENDING")
  attempts       Int                        @default(0)
  maxAttempts    Int                        @default(8)
  availableAt    DateTime                   @default(now())
  lockedAt       DateTime?
  leaseExpiresAt DateTime?
  lockToken      String?
  processedAt    DateTime?
  lastError      String?
  logs           IntegrationLog[]
  replayCommands IntegrationReplayCommand[]
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt

  @@index([status, availableAt, createdAt])
  @@index([status, leaseExpiresAt])
  @@index([topic, status, availableAt])
  @@index([aggregateType, aggregateId, createdAt])
}

model IntegrationReplayCommand {
  id            String                 @id @default(cuid())
  requestId     String                 @unique
  requestHash   String
  outboxEventId String
  outboxEvent   IntegrationOutboxEvent @relation(fields: [outboxEventId], references: [id], onDelete: Restrict)
  actorUserId   String
  actor         User                   @relation(fields: [actorUserId], references: [id], onDelete: Restrict)
  operation     String
  fromStatus    String
  resultStatus  String
  reason        String?
  createdAt     DateTime               @default(now())

  @@index([outboxEventId, createdAt])
  @@index([actorUserId, createdAt])
}
