{
  "name": "b2b-ekolglass",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src prisma --ext .ts,.tsx --cache --no-error-on-unmatched-pattern",
    "test": "vitest run --maxWorkers=4",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "smoke:admin": "node scripts/smoke-admin.mjs",
    "outbox:run": "node --env-file=.env scripts/run-outbox-worker.mjs",
    "auth-rate-limit:maintain": "node --env-file=.env scripts/run-auth-rate-limit-maintenance.mjs",
    "db:backup": "tsx --env-file=.env scripts/backup-sqlite.ts",
    "db:restore:verify": "tsx scripts/verify-sqlite-backup.ts",
    "media:reconcile": "tsx --env-file=.env scripts/reconcile-media.ts",
    "catalog:import": "tsx scripts/import-products-csv.ts",
    "check": "npm run lint && npm run test && npm run build"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1086.0",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.11.1",
    "clsx": "^2.1.1",
    "csv-parse": "^6.2.1",
    "lucide-react": "^1.23.0",
    "next": "16.2.10",
    "nodemailer": "^9.0.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "jsdom": "^29.1.1",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
