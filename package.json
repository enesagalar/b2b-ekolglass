{
  "name": "b2b-ekolglass",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.23.1 <25"
  },
  "packageManager": "npm@10.9.4",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "npm run preflight:production && next start",
    "start:ci": "next start",
    "lint": "eslint src prisma --ext .ts,.tsx --cache --no-error-on-unmatched-pattern",
    "test": "vitest run --maxWorkers=4",
    "test:node": "node --test scripts/*.test.mjs",
    "test:watch": "vitest",
    "test:db:prepare": "tsx scripts/prepare-test-database.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate:verify": "tsx scripts/verify-migration-integrity.ts",
    "prisma:migrate:reconcile": "tsx scripts/reconcile-migration-checksums.ts",
    "db:seed": "tsx prisma/seed.ts",
    "db:bootstrap-admin": "node --env-file-if-exists=.env node_modules/tsx/dist/cli.mjs scripts/bootstrap-initial-admin.ts",
    "smoke:admin": "node scripts/smoke-admin.mjs",
    "outbox:run": "node --env-file-if-exists=.env scripts/run-outbox-worker.mjs",
    "auth-rate-limit:maintain": "node --env-file-if-exists=.env scripts/run-auth-rate-limit-maintenance.mjs",
    "db:backup": "node --env-file-if-exists=.env node_modules/tsx/dist/cli.mjs scripts/backup-sqlite.ts",
    "db:release-prepare": "node --env-file-if-exists=.env node_modules/tsx/dist/cli.mjs scripts/prepare-production-database.ts",
    "db:backup:run": "node --env-file-if-exists=.env scripts/run-database-backup.mjs",
    "system-jobs:maintain": "node --env-file-if-exists=.env scripts/run-system-job-maintenance.mjs",
    "system-alerts:run": "node --env-file-if-exists=.env scripts/run-system-alert-dispatch.mjs",
    "db:restore:verify": "tsx scripts/verify-sqlite-backup.ts",
    "recovery:drill": "tsx scripts/run-isolated-recovery-drill.ts",
    "media:reconcile": "node --env-file-if-exists=.env node_modules/tsx/dist/cli.mjs scripts/reconcile-media.ts",
    "preflight:production": "tsx scripts/production-preflight.ts",
    "release:manifest": "node scripts/create-release-artifact-manifest.mjs",
    "rollback:validate": "node scripts/validate-rollback-manifest.mjs",
    "evidence:collect": "node scripts/collect-production-evidence.mjs",
    "catalog:import": "tsx scripts/import-products-csv.ts",
    "typecheck": "next typegen && tsc --noEmit",
    "check": "npm run lint && npm run typecheck && npm run test:node && npm run test && npm run build"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1086.0",
    "@prisma/adapter-better-sqlite3": "^7.9.0",
    "@prisma/client": "^7.9.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.11.1",
    "clsx": "^2.1.1",
    "csv-parse": "^6.2.1",
    "lucide-react": "^1.23.0",
    "next": "16.2.11",
    "nodemailer": "^9.0.3",
    "prisma": "^7.9.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tsx": "^4.22.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.11",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "overrides": {
    "sharp": "0.35.3",
    "postcss": "8.5.22"
  }
}
