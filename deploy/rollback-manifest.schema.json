{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ekolglass.com/schemas/b2b-rollback-manifest-v1.json",
  "title": "EkolGlass B2B rollback manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "reason", "current", "previous", "migration", "approvedAt"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "reason": { "type": "string", "minLength": 10, "maxLength": 500 },
    "approvedAt": { "type": "string", "format": "date-time" },
    "current": { "$ref": "#/$defs/release" },
    "previous": { "$ref": "#/$defs/release" },
    "migration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["compatibility", "backupManifestId", "backupSha256"],
      "properties": {
        "compatibility": { "enum": ["BACKWARD_COMPATIBLE", "RESTORE_REQUIRED"] },
        "backupManifestId": { "type": "string", "minLength": 1, "maxLength": 200 },
        "backupSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    }
  },
  "$defs": {
    "release": {
      "type": "object",
      "additionalProperties": false,
      "required": ["releaseId", "commitSha", "artifactDigest"],
      "properties": {
        "releaseId": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$" },
        "commitSha": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
        "artifactDigest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
      }
    }
  }
}
